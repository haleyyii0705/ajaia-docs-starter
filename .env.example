# Copy to ".env" in the project root (do not commit real keys).
# Restart `npm run dev` after creating or changing this file.
#
# Supabase → Project Settings → API:
#   - Project URL → VITE_SUPABASE_URL
#   - New projects: "Publishable" key (sb_publishable_...) → VITE_SUPABASE_ANON_KEY
#   - Legacy: "anon" JWT (eyJ...) → same variable name, still works

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
